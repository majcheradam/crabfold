{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server ./src/index.ts",
    "typecheck": "tsgo --noEmit",
    "dev": "bun run --hot src/index.ts",
    "start": "./server",
    "test": "bun test src/",
    "test:integration": "bun test test/",
    "test:all": "bun test"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@crabfold/auth": "workspace:*",
    "@crabfold/db": "workspace:*",
    "@crabfold/env": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "ai": "^6.0.141",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@crabfold/config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "^5.9.3"
  }
}
